{
    "name":  "book-reader",
"version": "1.0.1",
    "description":  "A modern desktop PDF reader application with highlights and bookmarks",
    "main":  "main.js",
    "author":  "Book Reader Team",
    "license":  "MIT",
    "scripts":  {
                    "start":  "electron .",
                    "dev":  "concurrently \"npm run dev:react\" \"wait-on http://localhost:3000 \u0026\u0026 electron .\"",
                    "dev:react":  "react-scripts start",
                    "build:react":  "react-scripts build",
                    "build":  "npm run build:react \u0026\u0026 electron-builder",
                    "build:win":  "npm run build:react \u0026\u0026 electron-builder --win"
                },
"build": {
                  "appId": "com.bookreader.app",
                  "productName": "Book Reader",
                  "directories": {
                                       "buildResources": "build",
                                       "output": "dist"
                                   },
                  "win": {
                              "target": [
                                             {
                                                 "target": "dir",
                                                 "arch": [
                                                              "x64"
                                                          ]
                                             }
                                         ],
                              "icon": null
                          },
                  "files": [
                                "build/**/*",
                                "main.js",
                                "preload.js",
                                "node_modules/**/*",
                                "package.json"
                            ],
                  "npmRebuild": false,
                  "extraMetadata": {
                      "main": "main.js"
                  }
              },
    "dependencies":  {
                         "electron-store":  "^8.1.0",
                         "pdfjs-dist":  "^3.11.174",
                         "react":  "^18.2.0",
                         "react-dom":  "^18.2.0",
                         "react-icons":  "^4.12.0",
                         "uuid":  "^9.0.1"
                     },
    "devDependencies":  {
                            "concurrently":  "^8.2.2",
                            "electron":  "^28.1.0",
                            "electron-builder":  "^24.9.1",
                            "react-scripts":  "5.0.1",
                            "wait-on":  "^7.2.0"
                        },
    "browserslist":  {
                         "production":  [
                                            "\u003e0.2%",
                                            "not dead",
                                            "not op_mini all"
                                        ],
                         "development":  [
                                             "last 1 chrome version",
                                             "last 1 firefox version",
                                             "last 1 safari version"
                                         ]
                     },
    "homepage":  "./"
}
